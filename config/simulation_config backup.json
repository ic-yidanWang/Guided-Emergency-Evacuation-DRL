{
  "description": "Guided Evacuation Simulation Configuration",
  "domain": {
    "xmin": 0.0,
    "xmax": 10.0,
    "ymin": 0.0,
    "ymax": 10.0,
    "zmin": 0.0,
    "zmax": 2.0
  },
  "physics": {
    "rcut": 0.5,
    "dt": 0.2,
    "agent_speed_scale": 0.2
  },
  "agents": {
    "n_particle": 80,
    "add_guide_agent": true,
    "agent_size": 0.18,
    "use_knn": true,
    "knn_k": 5,
    "knn_max_distance": 1,
    "knn_filter_obstacles": true
  },
  "guide_parameters": {
    "guide_radius": 1.5,
    "perception_radius": 3.0,
    "guide_initial_position_mode": "fixed",
    "guide_initial_position": [5.0, 5.0, 0.5],
    "guide_size": 0.25,
    "speed_scale": 1.0,
    "memory_increase_rate": 5.0,
    "memory_decay_rate": 0.2
  },
  "exit_parameters": {
    "door_size": 0.46,
    "door_visible_radius": 1.5
  },
  "exits": [
    {"x": 5.0, "y": 10.0, "z": 0.5, "description": "Single exit at top center (absolute coordinates)"} 
  ],
  "obstacles": [
    {"type": "rectangle", "x": 5.0, "y": 1.5, "z": 0.5, "width": 5.0, "height": 0.5, "description": "Bottom barrier: must detour left/right first"},
    {"type": "rectangle", "x": 1.5, "y": 4.0, "z": 0.5, "width": 1.2, "height": 1.5, "description": "Left corridor obstacle (extra detour)"},
    {"type": "rectangle", "x": 7.5, "y": 4.0, "z": 0.5, "width": 2.2, "height": 0.5, "description": "Right corridor obstacle (extra detour)"},
    {"type": "rectangle", "x": 3.0, "y": 9.8, "z": 0.5, "width": 0.4, "height": 1.0, "description": "Exit corner top"},
    {"type": "rectangle", "x": 5.0, "y": 6.5, "z": 0.5, "width": 4.0, "height": 1.0, "description": "Exit corner bottom"},
    {"type": "rectangle", "x": 6.4, "y": 8.5, "z": 0.5, "width": 1.2, "height": 3.0, "description": "Exit corner right"}
  ],

  "simulation": {
    "num_steps": 200,
    "save_interval": 5,
    "output_dir": "output/guided"
  },
  "visualization": {
    "fps": 10,
    "gif_filename": "guided_animation.gif"
  },
  "train": {
    "visualize": true,
    "refresh_interval": 5,
    "max_guide_speed": 1.6,
    "guide_boundary_margin": 0.8,
    "use_boundary_penalty": false,
    "use_corner_penalty": false,
    "guide_boundary_penalty_scale": 1.2,
    "guide_corner_penalty_scale": 0.9,
    "time_penalty_scale": 0.001,
    "memory_step_reward_scale": 0.02,
    "memory_first_reward_scale": 0.1,
    "memory_exit_reward_scale": 0.08,
    "episodes": 60,
    "steps_per_episode": 400,
    "lr_actor": 0.0003,
    "lr_critic": 0.001,
    "optimizer": "adamw",
    "weight_decay": 0.01,
    "lr_scheduler": "cosine",
    "min_lr_ratio": 0.1,
    "gamma": 0.99,
    "log_std_init": 0.0,
    "exploration_noise_std": 0.25,
    "exploration_decay": 0.985,
    "save_model": false,
    "save_path": "output/guided/guide_agent.pt",
    "save_every_n_episodes": 0,
    "do_value_conformal": true
  },
  "value_conformal": {
    "alpha": 0.1,
    "calibration_episodes": 5,
    "every_n_episodes": 20,
    "output_dir": "output/guided/conformal",
    "figure_name": "conformal_value_interval.png"
  }
}